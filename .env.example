# Transport mode: "http" (default) or "stdio"
MCP_TRANSPORT=http

# HTTP mode settings (used when MCP_TRANSPORT=http)
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=3333

# Optional Bearer token for HTTP mode.
# If set, clients must send: Authorization: Bearer <token>
MCP_AUTH_TOKEN=change-me-strong-token

# Optional screenshot artifact directory.
# If not set, defaults to: %USERPROFILE%\Pictures\pc-control-mcp
# Example:
# MCP_SCREENSHOT_DIR=C:\Users\YourUser\Pictures\pc-control-mcp
